{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["results"],
  "properties": {
    "results": {
      "type": "array",
      "minItems": 1,
      "maxItems": 1,
      "items": {
        "type": "object",
        "required": [
          "sample_id",
          "primary_decision",
          "detected_issues",
          "evidence_refs",
          "confidence",
          "rationale"
        ],
        "properties": {
          "sample_id": {"type": "string"},
          "primary_decision": {"type": "string"},
          "detected_issues": {
            "type": "array",
            "items": {"type": "string"}
          },
          "evidence_refs": {
            "type": "array",
            "items": {"type": "string"}
          },
          "confidence": {
            "enum": ["low", "medium", "high"]
          },
          "rationale": {"type": "string"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
